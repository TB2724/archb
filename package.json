{
  "name": "archb",
  "displayName": "Archb",
  "description": "Automatically documents why you changed your code. Archb watches your edits, asks targeted questions, and generates changelogs.",
  "version": "0.1.0",
  "publisher": "archb",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/TB2724/archb"
  },
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "SCM Providers"
  ],
  "keywords": [
    "changelog",
    "documentation",
    "AI",
    "ollama",
    "chatgpt",
    "claude",
    "git",
    "code history",
    "developer tools",
    "automatic documentation"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "archb.toggleActive",
        "title": "Archb: Toggle Active"
      },
      {
        "command": "archb.openPanel",
        "title": "Archb: Open Panel"
      },
      {
        "command": "archb.pushToGithub",
        "title": "Archb: Push to GitHub"
      },
      {
        "command": "archb.saveSession",
        "title": "Archb: Save Session (ask questions)"
      },
      {
        "command": "archb.openGitSettings",
        "title": "Archb: Open Git Settings"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "archb-sidebar",
          "title": "Archb",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "archb-sidebar": [
        {
          "type": "webview",
          "id": "archb.sidebarView",
          "name": "Archb",
          "icon": "images/icon.png"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "diff": "^9.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/diff": "^5.2.1",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.9",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3"
  }
}
